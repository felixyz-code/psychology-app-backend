# Required. Replace every placeholder before running the backend.
DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<database>?schema=public"
JWT_SECRET="replace-with-strong-random-secret-minimum-32-characters"

# Optional runtime settings.
JWT_EXPIRES_IN="1d"
PORT=3000
NODE_ENV="development"
UPLOADS_PATH="uploads"
CORS_ORIGIN="http://localhost:4200,http://localhost:4201"
# Defaults to false in production and true in non-production environments.
SWAGGER_ENABLED="true"
# Keep 0 unless the deployment has an explicitly configured reverse proxy.
TRUST_PROXY_HOPS=0

# Docker only. Production web containers must keep this false and run
# `prisma migrate deploy` as a one-shot deployment step before startup.
MIGRATE_ON_START="false"

# Required only by `npm run seed`; it is not read by backend runtime startup.
# SEED_DEMO_PASSWORD=
